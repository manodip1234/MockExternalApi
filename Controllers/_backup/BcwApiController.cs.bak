            _apiKey           = config["BcwApi:ApiKey"]                      ?? "bcw-test-api-key-001";
            _hmacSecret       = config["BcwApi:HmacSecret"]                  ?? "bcw-test-api-key-001";
            _toleranceMinutes = config.GetValue("BcwApi:TimestampToleranceMinutes", 5);
            _logger           = logger;
        }

